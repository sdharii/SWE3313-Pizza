<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MenuPageController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Crust Type -->
    <Label layoutX="20" layoutY="20" text="Crust Type:"/>
    <ChoiceBox fx:id="crustTypeChoice" layoutX="120" layoutY="20">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Thin"/>
                <String fx:value="Regular"/>
                <String fx:value="Pan"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <!-- Crust Size -->
    <Label layoutX="20" layoutY="60" text="Crust Size:"/>
    <ChoiceBox fx:id="crustSizeChoice" layoutX="120" layoutY="60">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Small"/>
                <String fx:value="Medium"/>
                <String fx:value="Large"/>
                <String fx:value="Extra Large"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <!-- Sauce -->
    <Label layoutX="20" layoutY="100" text="Sauce:"/>
    <ChoiceBox fx:id="sauceChoice" layoutX="120" layoutY="100">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Marinara"/>
                <String fx:value="Alfredo"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <!-- Toppings -->
    <Label layoutX="20" layoutY="140" text="Topping:"/>
    <TextField fx:id="toppingInput" layoutX="120" layoutY="140" promptText="Enter topping"/>

    <!-- Beverage -->
    <Label layoutX="20" layoutY="180" text="Beverage:"/>
    <ChoiceBox fx:id="beverageChoice" layoutX="120" layoutY="180">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Coke"/>
                <String fx:value="Sprite"/>
                <String fx:value="Fanta"/>
                <String fx:value="No Drink"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <!-- Dessert -->
    <Label layoutX="20" layoutY="220" text="Dessert:"/>
    <ChoiceBox fx:id="dessertChoice" layoutX="120" layoutY="220">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Chocolate Chunk Cookie"/>
                <String fx:value="Cinnamon Roll"/>
                <String fx:value="Molten Lava Cake"/>
                <String fx:value="No Dessert"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <!-- Buttons -->
    <Button layoutX="20" layoutY="260" text="Add Order" onAction="#addOrder"/>
    <Button layoutX="120" layoutY="260" text="Edit Order" onAction="#editOrder"/>
    <Button layoutX="220" layoutY="260" text="Delete Order" onAction="#deleteOrder"/>

    <!-- Orders List -->
    <Label layoutX="20" layoutY="300" text="Current Orders:"/>
    <ListView fx:id="ordersListView" layoutX="120" layoutY="300" prefHeight="80" prefWidth="400"/>
</AnchorPane>